# Supabase 연결 환경변수 — 실제 값은 .env 에 넣고 커밋하지 말 것.
# 값 위치: Supabase 대시보드 → Project Settings → API

# 브라우저(클라이언트)용 — VITE_ 접두사는 번들에 노출됨(공개 가능 키만)
VITE_SUPABASE_URL="https://<project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<anon 또는 sb_publishable_ 키>"
VITE_SUPABASE_PROJECT_ID="<project-ref>"

# 서버(SSR/서버함수)용
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_PUBLISHABLE_KEY="<anon 또는 sb_publishable_ 키>"
SUPABASE_PROJECT_ID="<project-ref>"

# 서버 전용 비밀키 — RLS 우회(admin). 절대 클라이언트/깃에 노출 금지
SUPABASE_SERVICE_ROLE_KEY="<service_role 또는 sb_secret_ 키>"

# Toss 결제 (PG)
TOSS_CLIENT_KEY="mock_toss_payment_key_0000"
TOSS_SECRET_KEY="mock_toss_secret_key_0000"
POINT_CHARGE_CALLBACK_URL="https://example.com/payment/charge/callback"
POINT_WITHDRAW_CALLBACK_URL="https://example.com/payment/withdraw/callback"
